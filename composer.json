{
    "name": "rdrgzma/boilerplate-php",
    "description": "Boilerplate PHP Vanilla com PSR-4 e Services",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/",
            "Modules\\": "modules/"
        }
    },
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "optimize-autoloader": true
    }
}